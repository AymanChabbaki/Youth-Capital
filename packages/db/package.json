{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "tsx --env-file=../../.env ./node_modules/drizzle-kit/bin.js push --config ./drizzle.config.ts",
    "push-force": "tsx --env-file=../../.env ./node_modules/drizzle-kit/bin.js push --force --config ./drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9"
  }
}
